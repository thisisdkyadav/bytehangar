# --- ByteHangar server config ---

# Listeners
PORT=5100                       # public/edge plane (browser uploads + signed downloads)
INTERNAL_PORT=5101              # internal plane (reserved; single bind for now)

# Postgres (lazy-connected; /health works without it)
DATABASE_URL=postgres://bytehangar:bytehangar@localhost:5432/bytehangar

# Blob backend: "local" or "s3"
STORAGE_BACKEND=local
DATA_ROOT=./data                # local-disk root

# Inviolable global ceiling (bytes). Per-policy limits may only be stricter.
MAX_UPLOAD_BYTES=52428800       # 50 MiB

# Bootstrap admin token for provisioning tenants/keys. Empty => admin disabled.
ADMIN_TOKEN=

# Signed download URLs
SIGNED_URL_TTL_SECONDS=300
PUBLIC_BASE_URL=                # e.g. https://files.example.com; empty => relative paths
