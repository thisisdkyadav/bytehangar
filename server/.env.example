# --- ByteHangar server config ---

# Deployment environment: "development" | "production".
# In production, MASTER_KEY is required and an empty ALLOWED_ORIGINS warns.
APP_ENV=development

# Listeners — two planes on separate ports.
PORT=5100                       # public/edge plane (browser uploads + signed downloads)
BIND_ADDRESS=0.0.0.0            # public listener bind (internet-facing)
INTERNAL_PORT=5101              # internal plane (provisioning, catalog, grants, S2S)
INTERNAL_BIND_ADDRESS=127.0.0.1 # keep private; set to a private IP for cross-VM deploys

# CORS allow-list for the public plane (comma-separated). Empty => allow all (dev).
ALLOWED_ORIGINS=

# Per-client-IP rate limit on the public plane. 0 disables.
RATE_LIMIT_PER_SECOND=50
RATE_LIMIT_BURST=100
# Trust X-Forwarded-For/X-Real-IP for the client IP. Enable ONLY behind a trusted
# proxy; otherwise the limiter keys on the (unspoofable) socket peer.
TRUST_FORWARDED_FOR=false

# Allow outbound webhook / download-auth-callback requests to private, loopback,
# and link-local targets (disables the SSRF guard). Keep false in production.
ALLOW_PRIVATE_OUTBOUND=false

# Postgres (lazy-connected; /health works without it). Compose maps host port 5433.
DATABASE_URL=postgres://bytehangar:bytehangar@localhost:5433/bytehangar
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=0
DB_ACQUIRE_TIMEOUT_SECS=30

# Internal GC scheduler. 0 disables (run GC via POST /internal/v1/gc instead).
GC_INTERVAL_SECONDS=0
GC_RETENTION_SECONDS=86400      # trash window: only GC files soft-deleted >= this ago

# Blob backend: "local" or "s3"
STORAGE_BACKEND=local
DATA_ROOT=./data                # local-disk root

# S3-compatible backend (used when STORAGE_BACKEND=s3). Works with AWS S3, MinIO,
# Cloudflare R2, Backblaze B2. Set S3_ENDPOINT + S3_FORCE_PATH_STYLE=true for MinIO.
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=                    # e.g. http://localhost:9100 for compose MinIO; empty => AWS
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false       # true for MinIO

# Inviolable global ceiling (bytes). Per-policy limits may only be stricter.
MAX_UPLOAD_BYTES=52428800       # 50 MiB

# Bootstrap admin token for provisioning tenants/keys. Empty => admin disabled.
ADMIN_TOKEN=

# Encrypt tenant secrets (signing + webhook) at rest. Required in production.
MASTER_KEY=

# Signed download URLs
SIGNED_URL_TTL_SECONDS=300
PUBLIC_BASE_URL=                # e.g. https://files.example.com; empty => relative paths
